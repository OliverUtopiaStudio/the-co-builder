# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Direct PostgreSQL connection for Drizzle ORM (server-side only)
# Get from: Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Password for the stakeholder report page (/report)
# Stakeholders use this shared password instead of Supabase accounts
REPORT_PASSWORD=your-report-password-here

# Buffer (Marketing content plan → push to Buffer)
# Get token: https://buffer.com/developers/api | Channel ID from Buffer dashboard
BUFFER_ACCESS_TOKEN=
BUFFER_CHANNEL_ID=

# Software Factory Validator (feedback integration)
SF_VALIDATOR_FEEDBACK_URL=https://api.factory.8090.dev/v1/integration/validator/feedback
SF_VALIDATOR_APP_KEY=your-app-key-here
